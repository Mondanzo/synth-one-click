{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "deep-link:default",
    "deep-link:allow-is-registered",
    "store:default",
    "dialog:default",
    "core:window:allow-close",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://synthriderz.com/api/*"
        }
      ]
    },
    "upload:default"
  ]
}